{
  "name": "quickhire-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:migrate": "node src/database/migrations/runMigrationsCli.js",
    "db:seed": "node src/database/seeds/seed.js",
